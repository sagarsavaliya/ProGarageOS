APP_NAME=GarageFlow
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# For faster local API testing (less query logging): APP_DEBUG=false and LOG_LEVEL=warning
# Physical device testing: use your PC LAN IP, e.g. APP_URL=http://192.168.1.10:8000
APP_URL=http://localhost:8000
APP_VERSION=1.0.0
APP_TIMEZONE=Asia/Kolkata
APP_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=debug

# --- Database ---
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=garageflow
DB_USERNAME=garageflow
DB_PASSWORD=secret
DB_ROOT_PASSWORD=secret

# --- Cache / Queue / Session ---
BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
CACHE_STORE=redis

# --- Redis ---
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- Mail (Mailpit for local dev — http://localhost:8025) ---
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@garageflow.local"
MAIL_FROM_NAME="${APP_NAME}"

# --- Laravel Reverb (WebSockets — Phase 2) ---
REVERB_APP_ID=garageflow-dev
REVERB_APP_KEY=garageflow-dev-key
REVERB_APP_SECRET=garageflow-dev-secret
REVERB_HOST=localhost
REVERB_PORT=6001
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# --- Sanctum (Flutter app auth) ---
SANCTUM_STATEFUL_DOMAINS=localhost:8000

# --- Cloudflare R2 Storage (leave empty for local dev — uses local disk) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=auto
AWS_BUCKET=
AWS_ENDPOINT=
AWS_URL=

# --- Firebase (Push notifications) ---
FIREBASE_CREDENTIALS=
FCM_SERVER_KEY=

# --- WhatsApp (Meta Cloud API) ---
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_OTP_TEMPLATE=pro_garage_otp
WHATSAPP_TEMPLATE_LANGUAGE=en
WHATSAPP_API_VERSION=v20.0
