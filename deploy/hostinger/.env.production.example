# Pro Garage OS — Hostinger KVM2 production environment
# Copy to: /var/www/progarage/.env
# Generate APP_KEY: php artisan key:generate --show

APP_NAME="Pro Garage OS"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.progarageos.com
APP_VERSION=1.0.0
APP_TIMEZONE=Asia/Kolkata
APP_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=progarage
DB_USERNAME=progarage
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_ROOT_PASSWORD=CHANGE_ME_ROOT_PASSWORD

CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_FROM_ADDRESS=noreply@progarageos.com
MAIL_FROM_NAME="${APP_NAME}"

SANCTUM_STATEFUL_DOMAINS=api.progarageos.com

REQUIRE_DELIVERY_INSPECTION=true

# Optional — R2 for inspection photos in production
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=auto
# AWS_BUCKET=
# AWS_ENDPOINT=
# AWS_URL=
